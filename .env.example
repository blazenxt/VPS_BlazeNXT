APP_ENV=production
APP_SECRET=replace-with-at-least-32-random-bytes
WEB_BASE_URL=https://hosting.blazenxt.in
DATABASE_URL=postgresql+psycopg://user:password@host:5432/db
BOT_TOKEN=
BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=replace-with-random-url-safe-secret
OWNER_IDS=123456789

# Optional login providers. Configure provider callback URLs using WEB_BASE_URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional email magic links (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=BlazeNXT <login@example.com>
SMTP_STARTTLS=true
MAGIC_LINK_TTL_SECONDS=900
MAX_UPLOAD_MB=10
# Railway Trial: control plane + Postgres leaves roughly 3 workload services.
# Set 0 for no application-level global limit.
# Paid/Pro default: 0 means no BlazeNXT application cap; Railway billing/limits still apply.
GLOBAL_WORKLOAD_LIMIT=0
ENABLE_DATABASE_PROVISIONING=true
DEFAULT_CPU_VCPUS=0.5
DEFAULT_MEMORY_MB=512
MAX_DATABASES_PER_WORKLOAD=1
SESSION_TTL_SECONDS=86400
RAILWAY_API_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT_ID=
RAILWAY_RUNNER_IMAGE=ghcr.io/blazenxt/vps-blazenxt-runner:latest
RAILWAY_API_URL=https://backboard.railway.com/graphql/v2
RUNNER_TOKEN_TTL_SECONDS=2592000
